        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Cada flor cuenta una historia",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Creamos arreglos florales únicos con las flores más frescas, cuidadosamente seleccionadas para celebrar tus momentos más especiales. Desde bouquets románticos hasta centros de mesa para eventos.</p>"
          }
        },
        "button": {
          "type": "buttons",
          "settings": {
            "button_label": "Conoce nuestra historia",
            "button_link": "shopify://pages/about",
            "button_style_secondary": true
          }
        }
      },
      "block_order": ["subheading", "heading", "text", "button"],
      "settings": {
        "color_scheme": "scheme-1",
        "full_width": true,
        "padding_top": 60,
        "padding_bottom": 40
      }
    },
    "featured_collection": {
      "type": "featured-collection",
      "settings": {
        "title": "Nuestros Arreglos",
        "heading_size": "h2",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": 4,
        "color_scheme": "scheme-2",
        "show_view_all": true,
        "view_all_style": "link",
        "enable_desktop_slider": false,
        "swipe_on_mobile": true,
        "image_ratio": "portrait",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "quick_add": "standard",
        "columns_mobile": "2",
        "padding_top": 48,
        "padding_bottom": 48
      }
    },
    "image_with_text": {
      "type": "image-with-text",
