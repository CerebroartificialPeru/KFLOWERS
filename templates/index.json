        "collection-1": {
          "type": "featured_collection",
          "settings": {
            "collection": ""
          }
        },
        "collection-2": {
          "type": "featured_collection",
          "settings": {
            "collection": ""
          }
        }
      },
      "block_order": ["collection-0", "collection-1", "collection-2"],
