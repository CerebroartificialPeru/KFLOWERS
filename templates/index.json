      "block_order": ["caption", "heading", "text", "button"],
      "settings": {
        "image_position": "left",
        "color_scheme": "scheme-1",
        "height": "adapt",
        "text_alignment": "left",
        "desktop_image_width": "medium",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "multicolumn": {
      "type": "multicolumn",
      "blocks": {
        "column1": {
          "type": "column",
          "settings": {
            "title": "Flores Frescas",
            "text": "<p>Recibimos nuevas flores cada mañana directamente de los mejores cultivos para garantizar la máxima frescura.</p>",
            "link_label": "",
            "link": "",
            "icon_name": "icon-leaf"
          }
        },
        "column2": {
          "type": "column",
          "settings": {
            "title": "Diseño Artesanal",
            "text": "<p>Cada arreglo es creado a mano por nuestros floristas expertos, con atención personalizada a cada detalle.</p>",
            "link_label": "",
            "link": "",
            "icon_name": "icon-gift"
          }
        },
        "column3": {
          "type": "column",
          "settings": {
            "title": "Entrega a Domicilio",
            "text": "<p>Llevamos tu pedido directo a la puerta. Entrega el mismo día disponible en pedidos antes del mediodía.</p>",
            "link_label": "",
            "link": "",
            "icon_name": "icon-truck"
          }
        }
      },
      "block_order": ["column1", "column2", "column3"],
      "settings": {
        "title": "¿Por qué elegirnos?",
        "heading_size": "h2",
        "image_width": "third",
        "image_ratio": "adapt",
        "columns_desktop": 3,
        "column_alignment": "center",
        "background_style": "primary",
        "button_label": "",
        "button_link": "",
        "swipe_on_mobile": false,
        "color_scheme": "scheme-2",
        "columns_mobile": "1",
        "padding_top": 48,
        "padding_bottom": 48
