{
  "sections": {
    "announcement_bar": {
      "type": "announcement-bar",
      "blocks": {
        "announcement": {
          "type": "announcement",
          "settings": {
            "text": "Envío gratis en pedidos mayores a $500 · Flores frescas todos los días",
            "text_alignment": "center",
            "link": ""
          }
        }
      },
      "block_order": ["announcement"],
      "settings": {
        "color_scheme": "scheme-4",
        "auto_rotate": false,
        "change_slides_speed": 5
      }
    },
    "image_banner": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Flores que expresan lo que las palabras no pueden",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "Arreglos florales artesanales, bouquets y plantas para cada ocasión especial.",
            "text_style": "subtitle"
          }
        },
        "button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Ver colección",
            "button_link_1": "shopify://collections/all",
            "button_style_secondary_1": false,
            "button_label_2": "Nuestra historia",
            "button_link_2": "shopify://pages/about",
            "button_style_secondary_2": true
          }
        }
      },
      "block_order": ["heading", "text", "button"],
      "settings": {
        "image_overlay_opacity": 35,
        "image_height": "large",
        "desktop_content_position": "middle-center",
        "show_text_box": false,
        "desktop_content_alignment": "center",
        "color_scheme": "scheme-1",
        "mobile_content_alignment": "center",
        "stack_images_on_mobile": false,
        "show_text_below": false
      }
    },
    "rich_text": {
      "type": "rich-text",
