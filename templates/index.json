      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Únete a nuestra comunidad floral",
            "heading_size": "h2"
          }
        },
        "paragraph": {
          "type": "paragraph",
          "settings": {
            "text": "Recibe inspiración floral, ofertas exclusivas y novedades directamente en tu bandeja de entrada."
          }
        }
      },
      "block_order": ["heading", "paragraph"],
      "settings": {
        "color_scheme": "scheme-3",
