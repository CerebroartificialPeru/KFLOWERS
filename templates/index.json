            "heading_size": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Trabajamos directamente con productores locales para garantizar flores de la más alta calidad. Cada arreglo es elaborado a mano por nuestros floristas con pasión y dedicación.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Explorar arreglos",
            "button_link": "shopify://collections/all"
          }
